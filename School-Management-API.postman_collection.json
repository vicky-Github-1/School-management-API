            {
              "key": "longitude",
              "value": "77.2090"
            }
          ]
        },
        "description": "Returns schools sorted by distance from user coordinates."
      },
      "response": []
    },
    {
      "name": "List Schools (Missing Query)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listSchools",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listSchools"
          ]
        },
        "description": "Should return 400 validation errors for missing latitude/longitude."
