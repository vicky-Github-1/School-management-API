        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sunrise Public School\",\n  \"address\": \"Sector 62, Noida\",\n  \"latitude\": 28.6284,\n  \"longitude\": 77.3649\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "addSchool"
          ]
        },
        "description": "Adds a new school with valid payload."
      },
      "response": []
    },
    {
      "name": "Add School (Invalid Payload)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"address\": \"\",\n  \"latitude\": 120,\n  \"longitude\": 200\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/addSchool",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "addSchool"
          ]
        },
        "description": "Should return 400 validation errors."
      },
      "response": []
    },
    {
      "name": "List Schools (Valid Query)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/listSchools?latitude=28.6139&longitude=77.2090",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "listSchools"
          ],
          "query": [
            {
              "key": "latitude",
              "value": "28.6139"
