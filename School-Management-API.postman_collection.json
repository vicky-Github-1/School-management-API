      "response": []
    },
    {
      "name": "List Schools via /api (Valid Query)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/listSchools?latitude=28.6139&longitude=77.2090",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
